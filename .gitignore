# =============================================================================
# .NET / ASP.NET Core — Build Artifacts
# Compiler output, intermediate build files, and local tool caches.
# These are regenerated by `dotnet build` and must never be committed.
# =============================================================================
bin/
obj/
*.dll
*.exe
*.pdb
*.nupkg
*.snupkg
TestResults/
coverage/
*.coveragexml
*.cobertura.xml

# =============================================================================
# .NET — Publish & Deployment Output
# Output of `dotnet publish` and any deployment zip created locally.
# CI/CD (GitHub Actions) produces these — they do not belong in source control.
# =============================================================================
publish_output/
**/publish_output/
PublishOutput/
app_deploy.zip
*.zip

# =============================================================================
# Visual Studio — IDE Files
# Machine-specific settings, breakpoints, and editor state.
# Each developer has their own — committing them causes constant conflicts.
# =============================================================================
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.userprefs
*.pidb
*.booproj
*.svd
*.opensdf
*.VC.opendb
*.VC.db
*.sdf
ipch/
.localhistory/
*.aps
*.ncb
*.opendb

# =============================================================================
# Visual Studio — Publish Profiles
# *.pubxml files store Azure deployment endpoints, SCM URLs, and usernames.
# Use GitHub Secrets (AZURE_WEBAPP_PUBLISH_PROFILE) for CI/CD instead.
# *.pubxml.user stores the password — never commit this.
# =============================================================================
**/Properties/PublishProfiles/*.pubxml
**/Properties/PublishProfiles/*.pubxml.user

# =============================================================================
# ASP.NET Core — Secrets & Environment Config
# Local developer secrets and environment-specific config.
# Production secrets go in Azure App Service → Configuration, NOT in files.
# =============================================================================
appsettings.Development.json
appsettings.Local.json
appsettings.*.local.json
firebase-credentials.json
secrets.json
*.pfx
*.p12
*.pem
*.key
*.cer

# =============================================================================
# ASP.NET Core — Runtime & Log Output
# Log files and local upload folders generated at runtime.
# =============================================================================
logs/
*.log
LogFiles/
wwwroot/uploads/
nlog.config.bak

# =============================================================================
# Node.js / React / Vite — Dependencies
# The node_modules folder is hundreds of MB and fully reproducible via
# `npm install`. Never commit it — use package-lock.json instead.
# =============================================================================
node_modules/
.npm/
.pnpm-store/

# =============================================================================
# Node.js / React / Vite — Build Output
# `dist/` is the compiled React app. Azure Static Web Apps builds this from
# source during deployment — committing it creates stale/conflicting output.
# =============================================================================
dist/
build/
out/
.output/
.nuxt/
.next/
.svelte-kit/

# =============================================================================
# Node.js / React / Vite — Cache & Tooling
# Local tool caches that are machine-specific and regenerated automatically.
# =============================================================================
.vite/
.eslintcache
*.tsbuildinfo
.parcel-cache/
.turbo/

# =============================================================================
# Node.js — Debug & Error Logs
# npm/yarn/pnpm write these on install/build errors. Never useful to track.
# =============================================================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml

# =============================================================================
# Environment Variables — Secrets
# .env files often contain API keys, DB passwords, and tokens.
# Only .env.example (template with no real values) should be committed.
# =============================================================================
.env
.env.*
!.env.example

# =============================================================================
# Docker — Local Compose State
# docker-compose.override.yml holds local dev overrides (ports, volumes, etc.)
# =============================================================================
docker-compose.override.yml
.docker/

# =============================================================================
# Operating System — Generated Files
# MacOS Finder metadata, Windows thumbnail cache, Linux temp files.
# These appear on every developer's machine regardless of the project.
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# =============================================================================
# JetBrains Rider / IntelliJ — IDE Files
# =============================================================================
.idea/
*.iml
*.ipr
*.iws

# =============================================================================
# Azure — Local Tool State
# Azure Functions local settings contain connection strings and secrets.
# =============================================================================
local.settings.json
.azure/
